{
  "name": "Mirko",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "lint": "eslint src --ext .js,.ts,.vue",
    "build": "tsc",
    "electron:dev": "electron .",
    "electron:build": "npm run frontend:build && electron-builder --win portable",
    "frontend:build": "cd Frontend && npm install && npm run build"
  },
  "build": {
    "appId": "com.mirko.app",
    "productName": "Mirko",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main.js",
      "preload.js",
      "Frontend/dist/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ]
    },
    "cscLink": null,
    "cscKeyPassword": null
  },
  "dependencies": {
    "axios": "1.13.5",
    "lucide-vue-next": "^0.563.0",
    "pinia": "^3.0.4"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^2.34.0",
    "@typescript-eslint/parser": "^2.34.0",
    "autoprefixer": "^10.4.24",
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0",
    "eslint-plugin-vue-i18n": "^0.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.5.3"
  },
  "private": true
}
